  {% endfor %}
</Accordion>

### Get a chat

```ts
const myChat = await im.chats.get(chatGuid);
```

{% set chatType = symbol("ts:@photon-ai/advanced-imessage#Chat") %}
The returned <TypeTooltip name="Chat" type={`{{ chatType.signature }}`} /> object contains the chat's identifiers, participants, latest message, and status flags.

### Count chats

```ts
const total = await im.chats.count();
const totalWithArchived = await im.chats.count({ includeArchived: true });
```

### Typing indicators

```ts
await im.chats.setTyping(chatGuid, true);

await im.chats.setTyping(chatGuid, false);
```

### Share contact info

```ts
await im.chats.shareContactInfo(chatGuid);
```

### Mark as read

```ts
await im.chats.markRead(chatGuid);
```

### Chat backgrounds

```ts
const hasBackground = await im.chats.hasBackground(chatGuid);

await im.chats.setBackground(chatGuid, imageBytes);

await im.chats.removeBackground(chatGuid);
```

### Real-time chat events

```ts
for await (const event of im.chats.subscribeEvents()) {
  event.type;
}
```

{% set chatEvent = symbol("ts:@photon-ai/advanced-imessage#ChatEvent") %}
