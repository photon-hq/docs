{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Photon",
  "colors": {
    "primary": "#47c6ed",
    "light": "#47c6ed",
    "dark": "#47c6ed"
  },
  "fonts": {
    "heading": {
      "family": "Aspekta",
      "source": "/fonts/AspektaVF.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "Inter"
    }
  },
  "favicon": "/favicon-128x128.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Advanced SDKs",
            "pages": [
              {
                "group": "iMessage",
                "icon": "apple",
                "pages": [
                  "advanced-kits/imessage/getting-started",
                  "advanced-kits/imessage/messages",
                  "advanced-kits/imessage/chats",
                  "advanced-kits/imessage/attachments",
                  "advanced-kits/imessage/scheduled-messages",
                  "advanced-kits/imessage/error-handling"
                ]
              },
              {
                "group": "Legacy",
                "pages": [
                  "legacy/imessage"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "href": "https://photon.codes/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Contact",
      "href": "https://photon.codes/contact"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/photon_hq",
      "github": "https://github.com/photon-hq",
      "linkedin": "https://www.linkedin.com/company/photonhq",
      "discord": "https://discord.gg/4c3VJzDfNA"
    }
  }
}
